# =====================================================
# API Key Wallet — environment variables
# Copy this to .env.local (for Next.js dev) and configure Wrangler secrets separately.
# =====================================================

# --- Supabase (https://supabase.com — create a free project in eu-central-1 / Frankfurt) ---
# Public anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key...

# Service role key (NEVER expose to browser; server actions / Workers only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your_service_role_key...

# --- Master Encryption Key (MEK) ---
# Generate with: openssl rand -base64 32
# Same value MUST be set as a secret in Cloudflare Workers (via `wrangler secret put MEK`).
MEK=YOUR_BASE64_32_BYTE_KEY

# --- Public URLs ---
# The wallet web app's public URL (used in OAuth redirects, magic-link emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# The Cloudflare Workers proxy URL (returned to vendors in the OAuth token response)
NEXT_PUBLIC_PROXY_URL=http://localhost:8787

# --- Google OAuth (for user sign-in) ---
# Configure at https://console.cloud.google.com/apis/credentials
# These go into Supabase's Auth → Providers → Google config, not directly in .env.
# Listed here for reference only.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Optional: Resend for transactional email (waitlist confirmations, etc.) ---
# RESEND_API_KEY=
